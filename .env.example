# OAuth2 credentials (shared across accounts)
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Account 1 — info@epoxyfloorpros.us
ACCOUNT_1_EMAIL=info@epoxyfloorpros.us
ACCOUNT_1_REFRESH_TOKEN=your_refresh_token_here

# Account 2 — jacob@clientkeeper.us
ACCOUNT_2_EMAIL=jacob@clientkeeper.us
ACCOUNT_2_REFRESH_TOKEN=your_refresh_token_here

# Optional bearer token to protect the endpoint
MCP_API_KEY=

# Transport: http (default) or stdio
MCP_TRANSPORT=http
